/dts-v1/;
#include <nordic/nrf52833_qdaa.dtsi>

/ {
	model = "slimevrmini_custom";
	compatible = "slimevrmini_custom";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,console = &cdc_acm_uart0;
		zephyr,shell-uart = &cdc_acm_uart0;
	};

	pwmleds {
		compatible = "pwm-leds";
		pwm_led0: pwm_led_0 { pwms = <&pwm0 0 PWM_MSEC(1) PWM_POLARITY_INVERTED>; };
		pwm_led1: pwm_led_1 { pwms = <&pwm0 1 PWM_MSEC(1) PWM_POLARITY_INVERTED>; };
		pwm_led2: pwm_led_2 { pwms = <&pwm0 2 PWM_MSEC(1) PWM_POLARITY_INVERTED>; };
	};

	leds {
		compatible = "gpio-leds";
		led0: led_0 { gpios = <&gpio0 15 (GPIO_OPEN_DRAIN | GPIO_ACTIVE_LOW)>; };  // red
		led1: led_1 { gpios = <&gpio0 17 (GPIO_OPEN_DRAIN | GPIO_ACTIVE_LOW)>; };  // green
		led2: led_2 { gpios = <&gpio0 20 (GPIO_OPEN_DRAIN | GPIO_ACTIVE_LOW)>; };  // blue
		led_bat: led_3 { gpios = <&gpio0 5 (GPIO_OPEN_DRAIN | GPIO_ACTIVE_LOW)>; }; // battery charging
	};

	buttons {
		compatible = "gpio-keys";
		button0: button_0 { gpios = <&gpio0 11 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>; label = "Push button switch 0"; };
	};

	aliases {
		sw0 = &button0;
		pwm-led0 = &pwm_led0;
		pwm-led1 = &pwm_led1;
		pwm-led2 = &pwm_led2;
		led0 = &led0;
		led1 = &led1;
		led2 = &led2;
		led-bat = &led_bat;
	};

	battery-divider {
		compatible = "voltage-divider";
		status = "okay";
		io-channels = <&adc 0>;     // ADC channel
		output-ohms = <536000>;
		full-ohms = <(887000+536000)>;
		power-gpios = <&gpio0 3 (GPIO_OPEN_DRAIN | GPIO_ACTIVE_LOW)>;
	};

	zephyr,user {
		int0-gpios = <&gpio0 29 GPIO_ACTIVE_HIGH>; // LSM6DSV INT1
	};
};

/* ---------- PINCTRL ---------- */
&pinctrl {

	spi0_default: spi0_default {
		group1 { psels = <NRF_PSEL(SPIM_SCK, 0, 30)>, <NRF_PSEL(SPIM_MOSI, 0, 31)>, <NRF_PSEL(SPIM_MISO, 0, 28)>; };
	};

	spi0_sleep: spi0_sleep {
		group1 { psels = <NRF_PSEL(SPIM_SCK, 0, 30)>, <NRF_PSEL(SPIM_MOSI, 0, 31)>, <NRF_PSEL(SPIM_MISO, 0, 28)>; low-power-enable; };
	};

	i2c0_default: i2c0_default {
		group1 { psels = <NRF_PSEL(TWIM_SDA, 0, 2)>, <NRF_PSEL(TWIM_SCL, 0, 3)>; };
	};

	i2c0_sleep: i2c0_sleep {
		group1 { psels = <NRF_PSEL(TWIM_SDA, 0, 2)>, <NRF_PSEL(TWIM_SCL, 0, 3)>; low-power-enable; };
	};

	pwm0_default: pwm0_default {
		group1 { psels = <NRF_PSEL(PWM_OUT0, 0, 15)>, <NRF_PSEL(PWM_OUT1, 0, 17)>, <NRF_PSEL(PWM_OUT2, 0, 20)>; nordic,drive-mode = <NRF_DRIVE_D0S1>; nordic,invert; };
	};

	pwm0_sleep: pwm0_sleep {
		group1 { psels = <NRF_PSEL(PWM_OUT0, 0, 15)>, <NRF_PSEL(PWM_OUT1, 0, 17)>, <NRF_PSEL(PWM_OUT2, 0, 20)>; low-power-enable; };
	};
};

/* ---------- REGULATOR ---------- */
&reg1 { regulator-initial-mode = <NRF5X_REG_MODE_DCDC>; };

/* ---------- ADC ---------- */
&adc { status = "okay"; };

/* ---------- GPIO ---------- */
&gpiote { status = "okay"; };
&gpio0 { status = "okay"; };
&gpio1 { status = "okay"; };

/* ---------- SPI0 (LSM6DSV) ---------- */
&spi0 {
	status = "okay";
	compatible = "nordic,nrf-spim";
	cs-gpios = <&gpio0 10 GPIO_ACTIVE_LOW>;
	pinctrl-0 = <&spi0_default>;
	pinctrl-1 = <&spi0_sleep>;
	pinctrl-names = "default", "sleep";
	clock-frequency = <DT_FREQ_M(8)>;

	imu_spi: lsm6dsv@0 {
		compatible = "vnd,spi-device";
		reg = <0>;
		spi-max-frequency = <DT_FREQ_M(10)>;
		label = "LSM6DSV";
		int1-gpios = <&gpio0 29 GPIO_ACTIVE_HIGH>;
	};
};

/* ---------- I2C0 (QMC6309) ---------- */
&i2c0 {
	compatible = "nordic,nrf-twim";
	status = "okay";
	pinctrl-0 = <&i2c0_default>;
	pinctrl-1 = <&i2c0_sleep>;
	pinctrl-names = "default", "sleep";
	clock-frequency = <I2C_BITRATE_FAST>;

	qmc6309: qmc6309@2c {
		compatible = "qst,qmc6309";
		reg = <0x2c>;
		label = "QMC6309";
	};
};

/* ---------- PWM ---------- */
&pwm0 {
	status = "okay";
	pinctrl-0 = <&pwm0_default>;
	pinctrl-1 = <&pwm0_sleep>;
	pinctrl-names = "default", "sleep";
};

/* ---------- USB ---------- */
zephyr_udc0: &usbd { compatible = "nordic,nrf-usbd"; status = "okay";
	cdc_acm_uart0: cdc_acm_uart0 { compatible = "zephyr,cdc-acm-uart"; };
};

/* ---------- Disable NFC ---------- */
&nfct { status = "disabled"; };